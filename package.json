{
  "name": "@ablegroup/design-system",
  "version": "2.0.0",
  "description": "_able Group design system — tokens, components, playbook",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src/tokens"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && npm run build:css",
    "build:css": "cp src/tokens/index.css dist/tokens.css",
    "build-storybook": "storybook build -o playbook-storybook",
    "storybook": "storybook dev -p 6006",
    "playbook": "open playbook/index.html",
    "lint": "eslint src --ext .jsx,.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "storybook": "^8.0.0",
    "vite": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@ablegroup:registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CredableTech/able-design-system.git"
  },
  "license": "UNLICENSED"
}
